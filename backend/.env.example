PORT=3000
# Comma-separated list of allowed CORS origins. Defaults to http://localhost:5173 if unset.
CORS_ORIGINS=
DATABASE_URL=postgresql://foodchestra:foodchestra@localhost:5432/foodchestra
# OpenFoodFacts API base URL. Override only if you mirror or proxy the upstream.
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org/api/v0/product
# RecallSwiss API base URL. Override only if you mirror or proxy the upstream.
RECALLSWISS_BASE_URL=
# URL of the agent service. Defaults to http://localhost:3001 if unset.
AGENT_URL=
